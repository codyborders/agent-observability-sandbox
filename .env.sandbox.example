# Copy this file to .env and fill in values from your own accounts.

# Required for chatbot and classifier LLM calls.
OPENAI_API_KEY=

# Required for Datadog telemetry. Use an API key from your own Datadog account.
DATADOG_API_KEY=
DD_SITE=datadoghq.com

# Sandbox tags. Change these freely when running experiments.
DD_ENV=sandbox
DD_SERVICE=agent-observability-sandbox
DD_VERSION=sandbox
DD_LLMOBS_ENABLED=1
DD_LLMOBS_ML_APP=agent-observability-sandbox

# Optional Datadog RUM Browser Application values.
DATADOG_RUM_APPLICATION_ID=
DATADOG_RUM_CLIENT_TOKEN=
DATADOG_RUM_SITE=datadoghq.com
DATADOG_RUM_SERVICE=agent-observability-sandbox
DATADOG_RUM_ENV=sandbox
DATADOG_RUM_VERSION=sandbox
DATADOG_RUM_SESSION_REPLAY=false
DATADOG_RUM_SAMPLE_RATE=100
DATADOG_RUM_TRACE_SAMPLE_RATE=100
DATADOG_RUM_PROFILING_SAMPLE_RATE=100
DATADOG_RUM_DEFAULT_PRIVACY_LEVEL=mask-user-input

# Optional scraper credentials. Leave blank unless you are testing Product Hunt API ingestion.
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=

# Sandbox behavior toggles.
SCRAPER_CRON_ENABLED=false
SANDBOX_RESTORE_SEED=true

# Datadog feature toggles for experimentation.
DD_PROFILING_ENABLED=true
DD_PROFILING_TIMELINE_ENABLED=true
DD_PROFILING_MEMORY_ENABLED=true
DD_RUNTIME_METRICS_ENABLED=true
DD_DYNAMIC_INSTRUMENTATION_ENABLED=false
DD_EXCEPTION_REPLAY_ENABLED=true
DD_LIVE_DEBUGGING_ENABLED=false
DD_APPSEC_ENABLED=false
DD_IAST_ENABLED=false
DD_LOGS_ENABLED=true
DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true
DD_PROCESS_AGENT_ENABLED=false
